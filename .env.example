# === Configuration de l'API IA (copier en .env et renseigner) ===

# --- Global ---
APP_NAME="Factur-IA API IA"
ENVIRONNEMENT="dev"                 # dev | test | prod
DEBUG="True"

# --- API (ce service) ---
API_HOST="localhost"
API_PORT="8001"                     # distinct de l'API data (8000) en local

# --- Sécurité / contrat inter-services ---
# MÊME valeur que l'API data. Générer via : openssl rand -hex 32
SECRET_OCR_TOKEN="changeme-shared-ocr-token"   # pragma: allowlist secret

# --- Callback vers l'API data ---
DATA_API_BASE_URL="http://localhost:8000"      # callback = base + /documents/webhook/ocr
HTTP_TIMEOUT_SECONDS="30"
HTTP_MAX_RETRIES="2"

# --- LLM Groq ---
GROQ_API_KEY="changeme-groq-api-key"           # pragma: allowlist secret
GROQ_MODEL="openai/gpt-oss-120b"               # supporte les structured outputs stricts (Groq)
GROQ_TIMEOUT_SECONDS="60"

# --- OCR / extraction ---
OCR_LANGUAGES="fr,en"
EASYOCR_GPU="False"
MAX_UPLOAD_SIZE_MB="10"

# --- CORS ---
CORS_ORIGINS="*"                    # à restreindre avant la prod
